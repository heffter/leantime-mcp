# ---------------------------------------------------------------------------
# leantime-mcp environment configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must never be committed. When running via docker-compose, this file is
# loaded with `env_file: .env`.
# ---------------------------------------------------------------------------

# Base URL of your Leantime instance. No trailing slash.
# The /api/jsonrpc path is appended automatically by the client.
#
# Two recommended shapes, depending on where Leantime runs:
#
#   1. Co-located deployment - MCP and Leantime on the SAME host.
#      Use the host's internal IP and Leantime's container/app port:
#        LEANTIME_URL=http://10.0.0.110:8090
#      Avoids round-tripping through DNS, your reverse proxy, and TLS
#      for traffic that never leaves the box. Faster, fewer moving parts,
#      no certificate-trust issues inside the container.
#
#   2. Cross-host deployment - MCP and Leantime on DIFFERENT machines.
#      Use the public DNS name with HTTPS so name resolution and
#      certificate verification both happen end to end:
#        LEANTIME_URL=https://leantime.example.com
#
LEANTIME_URL=https://your-leantime-instance.com

# Leantime API key (Company -> API Keys -> Generate new). Sent to Leantime
# as the X-API-KEY header. Treat as a secret; full read/write access to
# whatever data the issuing user can reach.
LEANTIME_API_KEY=your_api_key_here

# Email of the Leantime user the API key is associated with. Required by
# the server's startup checks; not currently sent on the wire.
LEANTIME_USER_EMAIL=you@example.com

# Logging verbosity. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Defaults to INFO if unset or invalid. NOTE: at DEBUG level, full RPC
# parameter payloads (ticket bodies, comments, timesheet text) are logged.
LOG_LEVEL=INFO

# Rate limiting (defaults match Leantime's stock LEAN_RATELIMIT_API of 10
# requests per 60-second window). Two layers; both optional:
#
#   Proactive pacing - keeps the client under Leantime's window so 429s
#     are rare. Set LEANTIME_RATE_LIMIT_PER_MIN to match LEAN_RATELIMIT_API
#     on your Leantime instance, and LEANTIME_RATE_BURST to the peak burst
#     you want to allow after a quiet period. Set rate=0 to disable
#     proactive pacing entirely (rely only on the reactive retry below).
#     Note: Leantime's stock LEAN_RATELIMIT_API default is 10 req/min,
#     which is very tight for AI-driven workflows. If you self-host you
#     can raise it on the Leantime side (env var on the Leantime
#     container) to e.g. 200 and match here.
#LEANTIME_RATE_LIMIT_PER_MIN=10
#LEANTIME_RATE_BURST=10
#
#   Bounded concurrency - cap on in-flight requests to Leantime.
#     Excess callers wait FIFO. Default 3 is safe for a typical
#     5-worker PHP-FPM pool with browser tabs / cron / health probes
#     also active. Get visibility via the get_queue_status MCP tool.
#LEANTIME_MAX_CONCURRENT=3
#
#   Reactive retry-on-429 - retry transient 429s with exponential backoff
#     and Retry-After honoring. Tweak only if Leantime's response is
#     unusually slow or if you want to tolerate longer outages.
#LEANTIME_MAX_RETRIES=5
#LEANTIME_BACKOFF_BASE=1.0
#LEANTIME_BACKOFF_CAP=30.0

# Per-request timeout in seconds. Default 30s; total worst-case budget
# with one retry is 30+30=60s, sized to fit inside Claude Code's MCP
# tool timeout (~60s). Raise only if your Leantime is genuinely slow;
# values >30s mean a worst-case budget that exceeds the client window
# and the user sees a generic client-side timeout instead of our nice
# -32099 error message. Idempotent reads (get*/list*/poll*/find*/etc.)
# retry once on ReadTimeout; writes never retry on timeout because the
# server may have already applied the operation and a duplicate could
# be created.
#LEANTIME_TIMEOUT=30.0
#LEANTIME_TIMEOUT_RETRIES=1
