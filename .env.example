# ---------------------------------------------------------------------------
# leantime-mcp environment configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must never be committed. When running via docker-compose, this file is
# loaded with `env_file: .env`.
# ---------------------------------------------------------------------------

# Base URL of your Leantime instance. No trailing slash.
# The /api/jsonrpc path is appended automatically by the client.
#
# Two recommended shapes, depending on where Leantime runs:
#
#   1. Co-located deployment - MCP and Leantime on the SAME host.
#      Use the host's internal IP and Leantime's container/app port:
#        LEANTIME_URL=http://10.0.0.110:8090
#      Avoids round-tripping through DNS, your reverse proxy, and TLS
#      for traffic that never leaves the box. Faster, fewer moving parts,
#      no certificate-trust issues inside the container.
#
#   2. Cross-host deployment - MCP and Leantime on DIFFERENT machines.
#      Use the public DNS name with HTTPS so name resolution and
#      certificate verification both happen end to end:
#        LEANTIME_URL=https://leantime.example.com
#
LEANTIME_URL=https://your-leantime-instance.com

# Leantime API key (Company -> API Keys -> Generate new). Sent to Leantime
# as the X-API-KEY header. Treat as a secret; full read/write access to
# whatever data the issuing user can reach.
LEANTIME_API_KEY=your_api_key_here

# Email of the Leantime user the API key is associated with. Required by
# the server's startup checks; not currently sent on the wire.
LEANTIME_USER_EMAIL=you@example.com

# Logging verbosity. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Defaults to INFO if unset or invalid. NOTE: at DEBUG level, full RPC
# parameter payloads (ticket bodies, comments, timesheet text) are logged.
LOG_LEVEL=INFO
